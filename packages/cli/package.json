{
  "name": "frontier-fe",
  "version": "0.2.1",
  "description": "shadcn-style CLI for scaffolding SOP-compliant React + Vite projects. Add UI components, features, hooks, layouts, and pages on demand.",
  "type": "module",
  "bin": {
    "frontier-fe": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "registry"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsudsda/frontier-fe-template.git"
  },
  "homepage": "https://github.com/rsudsda/frontier-fe-template#readme",
  "bugs": {
    "url": "https://github.com/rsudsda/frontier-fe-template/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "react",
    "vite",
    "template",
    "cli",
    "frontend",
    "scaffold"
  ],
  "license": "MIT"
}
