# ============================================
# Docker build context exclusion
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# Build outputs
dist
dist-ssr
build
.next
out
.tsbuildinfo

# Testing
coverage
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
test
tests
.vitest

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-*

# Git
.git
.gitignore
.gitattributes
.github

# CI/CD
.gitlab-ci.yml
.travis.yml
.circleci

# Documentation (keep for production reference)
*.md
!README.md
docs

# Docker (exclude from build context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs
*.log

# Misc
.husky
.editorconfig
.prettierrc*
.eslintrc*
.eslintignore
.prettierignore
.cursorignore
.cursor
vitest.config.ts

# OS files
Thumbs.db
.DS_Store
*.bak
*.tmp

# Claude/LLM files
.claude
.remember
-memory.md

# Docker artifacts
docker/data
docker/logs
docker/temp

# Lock files (keep package.json for dependencies)
pnpm-lock.yaml
yarn.lock
